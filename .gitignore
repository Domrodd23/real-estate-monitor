# Secrets — never commit
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.python-version

# Raw + processed data are regenerated by the pipeline; don't commit the bulk.
# (.gitkeep files keep the empty folders in git.)
data/raw/*
data/processed/*
!data/**/.gitkeep

# OS
.DS_Store

# Local editor/preview tooling (machine-specific paths)
.claude/

# NOTE: /docs is intentionally NOT ignored — GitHub Pages serves the dashboard
# from there, so the generated index.html and assets must be committed.
