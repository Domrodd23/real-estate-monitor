<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>National county map — real estate monitor</title>
<script src="assets/plotly.min.js"></script>
<style>
  :root { --accent:#1f6feb; --ink:#1b1f23; --muted:#5b6670; --line:#e3e7eb; }
  * { box-sizing:border-box; }
  body { margin:0; color:var(--ink); background:#fff;
         font-family:-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
  .topbar { display:flex; align-items:baseline; gap:14px; flex-wrap:wrap; padding:16px 22px 4px; }
  .topbar h1 { font-size:1.35rem; margin:0; }
  .topbar a { color:var(--accent); text-decoration:none; font-size:.9rem; }
  .topbar a:hover { text-decoration:underline; }
  .topbar .gen { color:var(--muted); font-size:.8rem; margin-left:auto; }
  .pillbar { display:flex; gap:8px; flex-wrap:wrap; padding:10px 22px 8px; }
  .pill { border:1px solid var(--line); background:#f6f8fa; color:#33404d; border-radius:999px;
          padding:7px 15px; font-size:.85rem; font-weight:500; cursor:pointer;
          transition:background .15s, color .15s, border-color .15s, box-shadow .15s; }
  .pill:hover { border-color:var(--accent); color:var(--accent); }
  .pill.active { background:var(--accent); border-color:var(--accent); color:#fff;
                 box-shadow:0 1px 5px rgba(31,111,235,.35); }
  .mapwrap { padding:0 22px; }
  #usmap { border:1px solid var(--line); border-radius:10px; overflow:hidden;
           box-shadow:0 1px 6px rgba(0,0,0,.05); }
  .note { color:var(--muted); font-size:.82rem; padding:12px 22px 34px; max-width:1000px; line-height:1.5; }
</style>
</head>
<body>
  <div class="topbar">
    <a href="index.html">← Dashboard</a>
    <h1>National county map</h1>
    <span class="gen">Updated {{ generated }}</span>
  </div>

  <div class="pillbar">
    {% for m in metrics %}
    <button class="pill {% if loop.first %}active{% endif %}" data-key="{{ m.key }}"
            onclick="setMetric(this)">{{ m.label }}</button>
    {% endfor %}
  </div>

  <div class="mapwrap">{{ chart | safe }}</div>

  <p class="note">
    Every US county, color-coded by the metric you pick above. Hover a county for
    its value; drag to pan. Your markets (<strong>{{ tracked | join(', ') }}</strong>)
    are outlined in black. Gray counties have no public value for the selected
    metric. Coverage: home value {{ coverage.home_value }}/{{ coverage.total }} counties,
    rent {{ coverage.rent }}, income {{ coverage.income }}. Sources: Zillow ZHVI/ZORI
    (county) + Census ACS 5-year. Public data, not a forecast.
  </p>

<script>
const METRICS = {{ metric_data_json | safe }};
function setMetric(btn){
  document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  const m = METRICS[btn.dataset.key];
  Plotly.restyle('usmap', {
    z: [m.z], text: [m.text], zmin: m.zmin, zmax: m.zmax,
    colorscale: [m.colorscale], 'colorbar.title.text': m.label
  }, [0]);
}
</script>
</body>
</html>
