<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>National map — real estate monitor</title>
<link href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" rel="stylesheet">
<script src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
<script src="https://unpkg.com/pmtiles@3.2.1/dist/pmtiles.js"></script>
<style>
  :root { --accent:#1f6feb; --ink:#1b1f23; --muted:#5b6670; --line:#e3e7eb; }
  * { box-sizing:border-box; }
  body { margin:0; color:var(--ink); background:#fff;
         font-family:-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
  .topbar { display:flex; align-items:baseline; gap:14px; flex-wrap:wrap; padding:16px 22px 4px; }
  .topbar h1 { font-size:1.35rem; margin:0; }
  .topbar a { color:var(--accent); text-decoration:none; font-size:.9rem; }
  .topbar a:hover { text-decoration:underline; }
  .topbar .gen { color:var(--muted); font-size:.8rem; margin-left:auto; }
  .pillbar { display:flex; gap:8px; flex-wrap:wrap; padding:10px 22px 6px; }
  .pill { border:1px solid var(--line); background:#f6f8fa; color:#33404d; border-radius:999px;
          padding:7px 15px; font-size:.85rem; font-weight:500; cursor:pointer;
          transition:background .15s, color .15s, border-color .15s, box-shadow .15s; }
  .pill:hover { border-color:var(--accent); color:var(--accent); }
  .pill.active { background:var(--accent); border-color:var(--accent); color:#fff;
                 box-shadow:0 1px 5px rgba(31,111,235,.35); }
  .legend { display:flex; align-items:center; gap:10px; flex-wrap:wrap; padding:2px 22px 8px; font-size:.76rem; color:var(--muted); }
  .legend .lt { font-weight:600; color:#33404d; }
  .legend .lv { font-variant-numeric:tabular-nums; }
  .legend .lbar { width:260px; height:12px; border-radius:7px; display:inline-block;
                  border:1px solid rgba(0,0,0,0.12); }
  .mapwrap { padding:0 22px; }
  #map { width:100%; height:76vh; min-height:480px; border:1px solid var(--line);
         border-radius:10px; box-shadow:0 1px 6px rgba(0,0,0,.05); overflow:hidden; }
  .maplibregl-popup-content { font-size:12.5px; padding:8px 11px; border-radius:7px; }
  .note { color:var(--muted); font-size:.82rem; padding:12px 22px 34px; max-width:1000px; line-height:1.5; }
</style>
</head>
<body>
  <div class="topbar">
    <a href="index.html">← Dashboard</a>
    <h1>National map</h1>
    <span class="gen">Updated {{ generated }}</span>
  </div>

  <div class="pillbar">
    {% for m in metrics %}
    <button class="pill {% if loop.first %}active{% endif %}" data-key="{{ m.key }}"
            onclick="setMetric(this)">{{ m.label }}</button>
    {% endfor %}
  </div>
  <div class="legend" id="legend"></div>

  <div class="mapwrap"><div id="map"></div></div>

  <p class="note">
    Drag to pan, scroll to zoom, hover for values. Zoom into a tracked state
    ({{ tracked | join(', ') }}) to drill down to <strong>ZIP-level</strong> detail.
    Gray areas have no public value for the selected metric. Coverage: home value
    {{ coverage.home_value }}/{{ coverage.total }} counties, rent {{ coverage.rent }},
    income {{ coverage.income }}. Sources: Zillow ZHVI/ZORI + Census ACS 5-year.
    Streamed as vector tiles. Public data, not a forecast.
  </p>

<script>
const METRICS = {{ metrics_json | safe }};
const HAS_ZIPS = {{ 'true' if zip_states else 'false' }};
const byKey = {}; METRICS.forEach(m => byKey[m.key] = m);
let currentKey = METRICS[0].key, firstSymbolId = null;

function fmt(kind, v){
  if(v === null || v === undefined || isNaN(v)) return 'n/a';
  if(kind === 'usd') return '$' + Math.round(v).toLocaleString();
  if(kind === 'usd_mo') return '$' + Math.round(v).toLocaleString() + '/mo';
  if(kind === 'pct') return (v >= 0 ? '+' : '') + v.toFixed(1) + '%';
  if(kind === 'ratio') return v.toFixed(1) + 'x';
  if(kind === 'count') return Math.round(v).toLocaleString();
  return v;
}
function setLegend(key){
  const L = byKey[key].legend;
  document.getElementById('legend').innerHTML =
    '<span class="lt">' + byKey[key].label + '</span>' +
    '<span class="lv">' + L.lo + '</span>' +
    '<span class="lbar" style="background:linear-gradient(to right,' + L.colors.join(',') + ')"></span>' +
    '<span class="lv">' + L.hi + '</span>';
}
setLegend(currentKey);

// Register the PMTiles protocol so MapLibre can stream our baked vector tiles.
maplibregl.addProtocol('pmtiles', new pmtiles.Protocol().tile);

function hover(layerId){
  const popup = new maplibregl.Popup({ closeButton:false, closeOnClick:false });
  map.on('mousemove', layerId, e => {
    map.getCanvas().style.cursor = 'pointer';
    const p = e.features[0].properties;
    popup.setLngLat(e.lngLat).setHTML('<strong>' + (p.cname || '') + '</strong><br>' +
      byKey[currentKey].label + ': ' + fmt(byKey[currentKey].fmt, p[currentKey])).addTo(map);
  });
  map.on('mouseleave', layerId, () => { map.getCanvas().style.cursor = ''; popup.remove(); });
}

function addLayers(){
  if(map.getLayer('counties-fill')) return;
  for(const l of map.getStyle().layers){ if(l.type === 'symbol'){ firstSymbolId = l.id; break; } }

  map.addSource('counties', { type:'vector', url:'pmtiles://counties.pmtiles' });
  map.addLayer({ id:'counties-fill', type:'fill', source:'counties', 'source-layer':'counties',
    paint:{ 'fill-color':byKey[currentKey].expr, 'fill-opacity':0.72 } }, firstSymbolId);
  map.addLayer({ id:'counties-line', type:'line', source:'counties', 'source-layer':'counties',
    paint:{ 'line-color':'rgba(90,100,110,0.25)', 'line-width':0.3 } }, firstSymbolId);

  if(HAS_ZIPS){
    map.addSource('zips', { type:'vector', url:'pmtiles://zips.pmtiles' });
    map.addLayer({ id:'zips-fill', type:'fill', source:'zips', 'source-layer':'zips', minzoom:6,
      paint:{ 'fill-color':byKey[currentKey].expr, 'fill-opacity':0.82 } }, firstSymbolId);
    map.addLayer({ id:'zips-line', type:'line', source:'zips', 'source-layer':'zips', minzoom:6,
      paint:{ 'line-color':'rgba(70,80,90,0.4)', 'line-width':0.5 } }, firstSymbolId);
  }
  // tracked counties outlined on top
  map.addLayer({ id:'tracked-line', type:'line', source:'counties', 'source-layer':'counties',
    filter:['==', ['get','tracked'], true], paint:{ 'line-color':'#111', 'line-width':2 } });

  hover('counties-fill');
  if(HAS_ZIPS) hover('zips-fill');
}

function setMetric(btn){
  document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  currentKey = btn.dataset.key;
  setLegend(currentKey);
  for(const id of ['counties-fill', 'zips-fill']){
    if(map.getLayer(id)) map.setPaintProperty(id, 'fill-color', byKey[currentKey].expr);
  }
}

let map;
try {
  map = new maplibregl.Map({
    container: 'map',
    style: 'https://basemaps.cartocdn.com/gl/positron-gl-style/style.json',
    center: [-96, 38.6], zoom: 3.4, maxZoom: 13, minZoom: 2, dragRotate: false });
  map.addControl(new maplibregl.NavigationControl({ showCompass:false }), 'top-right');
  map.on('load', addLayers);
  // The 'load' event can be unreliable with some vector styles, so also poll
  // until the style is ready and add the data layers then.
  const _iv = setInterval(() => {
    if(map.isStyleLoaded()){ addLayers(); if(map.getLayer('counties-fill')) clearInterval(_iv); }
  }, 250);
  setTimeout(() => clearInterval(_iv), 20000);
} catch(e){
  document.getElementById('map').innerHTML =
    '<p style="padding:24px;color:#5b6670">The map could not load. Please refresh the page.</p>';
}
</script>
</body>
</html>
